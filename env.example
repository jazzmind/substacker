# =============================================================================
# SUBSTACKER - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local for local development:
#   cp env.example .env.local

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

NODE_ENV=development
APP_NAME=substacker
SSO_AUDIENCE=
PORT=3008
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_APP_URL=http://localhost:3008
APP_MODE=frontend

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

NEXT_PUBLIC_BUSIBOX_PORTAL_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_BASE_PATH=/portal
AUTHZ_BASE_URL=http://localhost:8010

# =============================================================================
# BACKEND SERVICES
# =============================================================================

DEFAULT_API_AUDIENCE=data-api
DATA_API_URL=http://localhost:8002
AGENT_API_URL=http://localhost:8000
SEARCH_API_URL=http://localhost:8003

# =============================================================================
# SUBSTACK INTEGRATION
# =============================================================================
# Publication URL for substack-bridge.py (per-stack URLs are stored in data-api)
# SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com

# =============================================================================
# OPTIONAL: LOCAL DEVELOPMENT
# =============================================================================

# TEST_SESSION_JWT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...
VERBOSE_AUTHZ_LOGGING=false
DEBUG=false
